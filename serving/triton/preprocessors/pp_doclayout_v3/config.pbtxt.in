name: "@MODEL_NAME@"
backend: "pp_doclayout_v3_preprocess"
max_batch_size: 0
input [
  {
    name: "image"
    data_type: TYPE_STRING
    dims: [ 1 ]
  }
]
output [
  {
    name: "im_shape"
    data_type: TYPE_FP32
    dims: [ -1, 2 ]
  }
]
output [
  {
    name: "image"
    data_type: TYPE_FP32
    dims: [ -1, 3, 800, 800 ]
  }
]
output [
  {
    name: "scale_factor"
    data_type: TYPE_FP32
    dims: [ -1, 2 ]
  }
]
