name: "@MODEL_NAME@"
backend: "pp_doclayout_v3_preprocess"
max_batch_size: 8
dynamic_batching {}
input [
  {
    name: "image"
    data_type: TYPE_UINT8
    dims: [ -1 ]
  }
]
output [
  {
    name: "im_shape"
    data_type: TYPE_FP32
    dims: [ 2 ]
  }
]
output [
  {
    name: "image"
    data_type: TYPE_FP32
    dims: [ 3, 800, 800 ]
  }
]
output [
  {
    name: "scale_factor"
    data_type: TYPE_FP32
    dims: [ 2 ]
  }
]
